{
  "name": "ai-workflow",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "better-auth": "1.5.5",
      "ai": "^6.0.3",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18",
      "alchemy": "^0.90.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @ai-workflow/db db:push",
    "db:studio": "turbo -F @ai-workflow/db db:studio",
    "db:generate": "turbo -F @ai-workflow/db db:generate",
    "db:migrate": "turbo -F @ai-workflow/db db:migrate",
    "deploy": "turbo -F @ai-workflow/infra deploy",
    "destroy": "turbo -F @ai-workflow/infra destroy",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test:specs": "bun test tests/spec-workflow/"
  },
  "dependencies": {
    "@ai-workflow/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ai-workflow/config": "workspace:*",
    "@biomejs/biome": "2.4.10",
    "@cloudflare/workers-types": "^4.20251213.0",
    "@types/bun": "catalog:",
    "lefthook": "latest",
    "turbo": "^2.8.12",
    "typescript": "^5",
    "ultracite": "7.4.3"
  },
  "packageManager": "bun@1.3.11"
}
