{
  "mcpServers": {
    "better-t-stack": {
      "command": "bunx",
      "args": ["create-better-t-stack@latest", "mcp"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "cloudflare-docs": {
      "url": "https://docs.mcp.cloudflare.com/sse"
    },
    "shadcn": {
      "command": "npx",
      "args": ["-y", "shadcn@latest", "mcp"]
    },
    "neon": {
      "url": "https://mcp.neon.tech/mcp"
    },
    "better-auth": {
      "url": "https://mcp.inkeep.com/better-auth/mcp"
    }
  }
}
